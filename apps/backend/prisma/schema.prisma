generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id             String   @id @default(uuid()) @map("id")
  tenantId       String   @unique @map("tenant_id")
  name           String   @map("name")
  legalName      String   @map("legal_name")
  brandName      String   @map("brand_name")
  gstNumber      String   @map("gst_number")
  fssaiLicense   String   @map("fssai_license")
  panNumber      String   @map("pan_number")
  cinNumber      String?  @map("cin_number")
  logoUrl        String?  @map("logo_url")
  bannerUrl      String?  @map("banner_url")
  email          String   @map("email")
  phone          String   @map("phone")
  whatsapp       String   @map("whatsapp")
  website        String?  @map("website")
  description    String?  @map("description")
  country        String   @map("country")
  state          String   @map("state")
  city           String   @map("city")
  district       String   @map("district")
  postalCode     String   @map("postal_code")
  address        String   @map("address")
  lat            Float?   @map("lat")
  lng            Float?   @map("lng")
  currency       String   @default("INR") @map("currency")
  timeZone       String   @default("Asia/Kolkata") @map("time_zone")
  dateFormat     String   @default("DD/MM/YYYY") @map("date_format")
  timeFormat     String   @default("12h") @map("time_format")
  financialYear  String   @default("April-March") @map("financial_year")
  language       String   @default("en") @map("language")
  defaultTheme   String   @default("light") @map("default_theme")
  restaurantType String   @map("restaurant_type")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("restaurants")
}

model User {
  id                     String         @id @default(uuid()) @map("id")
  tenantId               String         @map("tenant_id")
  username               String         @map("username")
  passwordHash           String         @map("password_hash")
  email                  String         @map("email")
  phone                  String         @map("phone")
  pinHash                String?        @map("pin_hash")
  status                 String         @default("ACTIVE") @map("status")
  roleId                 String         @map("role_id")
  role                   Role           @relation(fields: [roleId], references: [id])
  employeeId             String?        @map("employee_id")
  profilePhoto           String?        @map("profile_photo")
  designation            String?        @map("designation")
  department             String?        @map("department")
  joiningDate            DateTime       @default(now()) @map("joining_date")
  languagePreference     String         @default("en") @map("language_preference")
  themePreference        String         @default("light") @map("theme_preference")
  notificationPreference String         @default("all") @map("notification_preference")
  sessions               UserSession[]
  auditLogs              AuditLog[]
  branches               UserBranch[]
  shifts                 UserShift[]

  @@unique([tenantId, username])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @map("id")
  tenantId    String           @map("tenant_id")
  name        String           @map("name")
  description String?          @map("description")
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @map("id")
  name        String           @unique @map("name")
  module      String           @map("module")
  description String?          @map("description")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Branch {
  id                  String          @id @default(uuid()) @map("id")
  tenantId            String          @map("tenant_id")
  name                String          @map("name")
  code                String          @map("code")
  phone               String          @map("phone")
  email               String          @map("email")
  managerId           String?         @map("manager_id")
  address             String          @map("address")
  workingHours        String          @map("working_hours")
  status              String          @default("ACTIVE") @map("status")
  timeZone            String          @default("Asia/Kolkata") @map("time_zone")
  currency            String          @default("INR") @map("currency")
  kitchenConfig       String?         @map("kitchen_config")
  deliveryRadius      Float?          @map("delivery_radius")
  receiptFooter       String?         @map("receipt_footer")
  invoiceHeader       String?         @map("invoice_header")
  taxRules            String?         @map("tax_rules")
  offlineSyncSettings String?         @map("offline_sync_settings")
  paymentOptions      String?         @map("payment_options")
  createdAt           DateTime        @default(now()) @map("created_at")
  users               UserBranch[]
  shifts              UserShift[]
  floors              Floor[]
  taxes               TaxConfig[]
  discounts           DiscountRule[]
  printers            PrinterConfig[]
  kitchens            KitchenConfig[]
  series              NumberSeries[]
  media               MediaMetadata[]
  items               MenuItem[]
  modifierGroups      ModifierGroup[]
  combos              ComboMeal[]
  tables              RestaurantTable[]
  reservations        Reservation[]
  waitlistEntries     WaitlistEntry[]
  orders              Order[]
  kots                KOT[]
  bills               Bill[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]

  @@unique([tenantId, code])
  @@map("branches")
}

model UserBranch {
  userId   String @map("user_id")
  branchId String @map("branch_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model UserShift {
  id             String    @id @default(uuid()) @map("id")
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId       String    @map("branch_id")
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedAt       DateTime  @default(now()) @map("opened_at")
  closedAt       DateTime? @map("closed_at")
  openingCash    Float     @map("opening_cash")
  closingCash    Float?    @map("closing_cash")
  expectedCash   Float?    @map("expected_cash")
  actualCash     Float?    @map("actual_cash")
  cashDifference Float?    @map("cash_difference")
  status         String    @default("OPEN") @map("status")
  notes          String?   @map("notes")
  createdAt      DateTime  @default(now()) @map("created_at")
  drawerLogs     CashDrawerLog[]

  @@map("user_shifts")
}

model Floor {
  id        String            @id @default(uuid()) @map("id")
  branchId  String            @map("branch_id")
  branch    Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String            @map("name")
  sortOrder Int               @default(0) @map("sort_order")
  status    String            @default("ACTIVE") @map("status")
  createdAt DateTime          @default(now()) @map("created_at")
  tables    RestaurantTable[]

  @@map("floors")
}

model TaxConfig {
  id         String   @id @default(uuid()) @map("id")
  branchId   String   @map("branch_id")
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String   @map("name")
  rate       Float    @map("rate")
  type       String   @map("type")
  isCompound Boolean  @default(false) @map("is_compound")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tax_configs")
}

model DiscountRule {
  id               String    @id @default(uuid()) @map("id")
  branchId         String    @map("branch_id")
  branch           Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name             String    @map("name")
  type             String    @map("type")
  value            Float     @map("value")
  minBillAmount    Float     @default(0) @map("min_bill_amount")
  maxDiscountValue Float?    @map("max_discount_value")
  couponCode       String?   @map("coupon_code")
  isActive         Boolean   @default(true) @map("is_active")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("discount_rules")
}

model PrinterConfig {
  id             String   @id @default(uuid()) @map("id")
  branchId       String   @map("branch_id")
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name           String   @map("name")
  type           String   @map("type")
  paperSize      String   @default("80mm") @map("paper_size")
  connectionType String   @map("connection_type")
  ipAddress      String?  @map("ip_address")
  portNumber     Int?     @map("port_number")
  autoPrintRules String?  @map("auto_print_rules")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("printer_configs")
}

model KitchenConfig {
  id          String   @id @default(uuid()) @map("id")
  branchId    String   @map("branch_id")
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name        String   @map("name")
  description String?  @map("description")
  categoryIds String?  @map("category_ids")
  printerId   String?  @map("printer_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("kitchen_configs")
}

model NumberSeries {
  id          String   @id @default(uuid()) @map("id")
  branchId    String   @map("branch_id")
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  entityType  String   @map("entity_type")
  prefix      String   @map("prefix")
  suffix      String?  @map("suffix")
  digits      Int      @default(6) @map("digits")
  nextNumber  Int      @default(1) @map("next_number")
  currentYear String?  @map("current_year")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([branchId, entityType])
  @@map("number_series")
}

model MediaMetadata {
  id        String   @id @default(uuid()) @map("id")
  tenantId  String   @map("tenant_id")
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  mimeType  String   @map("mime_type")
  fileSize  Int      @map("file_size")
  purpose   String   @map("purpose")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media_metadata")
}

// --- Menu management models ---

model Category {
  id           String     @id @default(uuid()) @map("id")
  tenantId     String     @map("tenant_id")
  name         String     @map("name")
  displayName  String     @map("display_name")
  code         String     @map("code")
  description  String?    @map("description")
  displayOrder Int        @default(0) @map("display_order")
  parentId     String?    @map("parent_id")
  parent       Category?  @relation("CategoryNesting", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryNesting")
  isActive     Boolean    @default(true) @map("is_active")
  branchIds    String?    @map("branch_ids")
  kitchenIds   String?    @map("kitchen_ids")
  createdAt    DateTime   @default(now()) @map("created_at")
  items        MenuItem[]

  @@unique([tenantId, code])
  @@map("categories")
}

model MenuItem {
  id             String             @id @default(uuid()) @map("id")
  categoryId     String             @map("category_id")
  category       Category           @relation(fields: [categoryId], references: [id])
  name           String             @map("name")
  shortName      String             @map("short_name")
  sku            String             @map("sku")
  barcode        String?            @map("barcode")
  itemCode       String             @map("item_code")
  description    String?            @map("description")
  isActive       Boolean            @default(true) @map("is_active")
  taxInclusive   Boolean            @default(false) @map("tax_inclusive")
  taxExclusive   Boolean            @default(true) @map("tax_exclusive")
  taxConfigId    String?            @map("tax_config_id")
  dineInPrice    Float              @map("dine_in_price")
  takeawayPrice  Float              @map("takeaway_price")
  deliveryPrice  Float              @map("delivery_price")
  happyHourPrice Float?             @map("happy_hour_price")
  weekendPrice   Float?             @map("weekend_price")
  branchId       String             @map("branch_id")
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now()) @map("created_at")
  variants       MenuItemVariant[]
  recipes        Recipe[]
  availabilities MenuAvailability[]
  comboItems     ComboItem[]

  @@unique([branchId, sku])
  @@map("menu_items")
}

model MenuItemVariant {
  id             String             @id @default(uuid()) @map("id")
  menuItemId     String             @map("menu_item_id")
  menuItem       MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name           String             @map("name")
  price          Float              @map("price")
  sku            String             @map("sku")
  barcode        String?            @map("barcode")
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")
  recipes        Recipe[]
  availabilities MenuAvailability[]

  @@unique([menuItemId, sku])
  @@map("menu_item_variants")
}

model ModifierGroup {
  id        String           @id @default(uuid()) @map("id")
  branchId  String           @map("branch_id")
  branch    Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String           @map("name")
  minSelect Int              @default(0) @map("min_select")
  maxSelect Int              @default(1) @map("max_select")
  createdAt DateTime         @default(now()) @map("created_at")
  options   ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id                 String        @id @default(uuid()) @map("id")
  modifierGroupId    String        @map("modifier_group_id")
  modifierGroup      ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name               String        @map("name")
  price              Float         @map("price")
  isFree             Boolean       @default(false) @map("is_free")
  maxQuantity        Int           @default(1) @map("max_quantity")
  kitchenInstructions String?      @map("kitchen_instructions")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")

  @@map("modifier_options")
}

model ComboMeal {
  id        String      @id @default(uuid()) @map("id")
  branchId  String      @map("branch_id")
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String      @map("name")
  price     Float       @map("price")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  items     ComboItem[]

  @@map("combo_meals")
}

model ComboItem {
  id           String    @id @default(uuid()) @map("id")
  comboMealId  String    @map("combo_meal_id")
  comboMeal    ComboMeal @relation(fields: [comboMealId], references: [id], onDelete: Cascade)
  menuItemId   String    @map("menu_item_id")
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity     Int       @default(1) @map("quantity")
  isOptional   Boolean   @default(false) @map("is_optional")
  upgradePrice Float     @default(0) @map("upgrade_price")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("combo_items")
}

model Ingredient {
  id            String              @id @default(uuid()) @map("id")
  tenantId      String              @map("tenant_id")
  name          String              @map("name")
  sku           String              @map("sku")
  unit          String              @map("unit")
  barcode       String?             @map("barcode")
  category      String              @default("RAW") @map("category")
  minStock      Float               @default(0) @map("min_stock")
  maxStock      Float               @default(100) @map("max_stock")
  reorderLevel  Float               @default(10) @map("reorder_level")
  currentStock  Float               @default(0) @map("current_stock")
  averageCost   Float               @default(0) @map("average_cost")
  status        String              @default("ACTIVE") @map("status")
  createdAt     DateTime            @default(now()) @map("created_at")
  recipes       RecipeIngredient[]
  movements     StockMovement[]
  poItems       PurchaseOrderItem[]
  transferItems StockTransferItem[]
  wastages      WastageEntry[]

  @@unique([tenantId, sku])
  @@map("ingredients")
}

model Recipe {
  id                String             @id @default(uuid()) @map("id")
  menuItemId        String?            @map("menu_item_id")
  menuItem          MenuItem?          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemVariantId String?            @map("menu_item_variant_id")
  menuItemVariant   MenuItemVariant?   @relation(fields: [menuItemVariantId], references: [id], onDelete: Cascade)
  instructions      String?            @map("instructions")
  createdAt         DateTime           @default(now()) @map("created_at")
  ingredients       RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id              String     @id @default(uuid()) @map("id")
  recipeId        String     @map("recipe_id")
  recipe          Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId    String     @map("ingredient_id")
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity        Float      @map("quantity")
  unit            String     @map("unit")
  wastePercentage Float      @default(0) @map("waste_percentage")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("recipe_ingredients")
}

model MenuAvailability {
  id                String           @id @default(uuid()) @map("id")
  menuItemId        String?          @map("menu_item_id")
  menuItem          MenuItem?        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemVariantId String?          @map("menu_item_variant_id")
  menuItemVariant   MenuItemVariant? @relation(fields: [menuItemVariantId], references: [id], onDelete: Cascade)
  type              String           @map("type")
  daysOfWeek        String?          @map("days_of_week")
  startTime         String?          @map("start_time")
  endTime           String?          @map("end_time")
  startDate         DateTime?        @map("start_date")
  endDate          DateTime?        @map("end_date")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@map("menu_availabilities")
}

// --- Seating layout models ---

model RestaurantTable {
  id              String        @id @default(uuid()) @map("id")
  floorId         String        @map("floor_id")
  floor           Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  branchId        String        @map("branch_id")
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  number          String        @map("number")
  name            String        @map("name")
  qrCode          String?       @map("qr_code")
  capacity        Int           @map("capacity")
  minCapacity     Int           @default(1) @map("min_capacity")
  maxCapacity     Int           @map("max_capacity")
  type            String        @map("type")
  status          String        @default("AVAILABLE") @map("status")
  posX            Int           @default(0) @map("pos_x")
  posY            Int           @default(0) @map("pos_y")
  width           Int           @default(80) @map("width")
  height          Int           @default(80) @map("height")
  rotate          Int           @default(0) @map("rotate")
  isActive        Boolean       @default(true) @map("is_active")
  parentMergeId   String?       @map("parent_merge_id")
  primaryWaiterId String?      @map("primary_waiter_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  reservations    Reservation[]

  @@unique([branchId, number])
  @@map("restaurant_tables")
}

model Reservation {
  id              String          @id @default(uuid()) @map("id")
  branchId        String          @map("branch_id")
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId         String?         @map("table_id")
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName    String          @map("customer_name")
  customerPhone   String          @map("customer_phone")
  reservationDate DateTime        @map("reservation_date")
  startTime       String          @map("start_time")
  guestsCount     Int             @map("guests_count")
  specialRequests String?         @map("special_requests")
  status          String          @default("CONFIRMED") @map("status")
  depositAmount   Float           @default(0) @map("deposit_amount")
  source          String          @default("WALK_IN") @map("source")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@map("reservations")
}

model WaitlistEntry {
  id                   String   @id @default(uuid()) @map("id")
  branchId             String   @map("branch_id")
  branch               Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerName         String   @map("customer_name")
  customerPhone        String   @map("customer_phone")
  guestsCount          Int      @map("guests_count")
  status               String   @default("WAITING") @map("status")
  estimatedWaitMinutes Int      @default(15) @map("estimated_wait_minutes")
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("waitlist_entries")
}

// --- Order & KOT transactional models ---

model Order {
  id            String      @id @default(uuid()) @map("id")
  branchId      String      @map("branch_id")
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  floorId       String?     @map("floor_id")
  tableId       String?     @map("table_id")
  customerName  String?     @map("customer_name")
  customerPhone String?     @map("customer_phone")
  waiterId      String?     @map("waiter_id")
  guestsCount   Int         @default(1) @map("guests_count")
  type          String      @map("type")
  status        String      @default("DRAFT") @map("status")
  priority      String      @default("NORMAL") @map("priority")
  notes         String?     @map("notes")
  source        String      @default("POS") @map("source")
  totalAmount   Float       @default(0) @map("total_amount")
  totalDiscount Float       @default(0) @map("total_discount")
  totalTax      Float       @default(0) @map("total_tax")
  heldAt        DateTime?   @map("held_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  items         OrderItem[]
  kots          KOT[]

  @@map("orders")
}

model OrderItem {
  id                String              @id @default(uuid()) @map("id")
  orderId           String              @map("order_id")
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId        String              @map("menu_item_id")
  menuItemVariantId String?             @map("menu_item_variant_id")
  name              String              @map("name")
  quantity          Int                 @map("quantity")
  unitPrice         Float               @map("unit_price")
  discountAmount    Float               @default(0) @map("discount_amount")
  taxAmount         Float               @default(0) @map("tax_amount")
  status            String              @default("NEW") @map("status")
  notes             String?             @map("notes")
  kitchenConfigId   String?             @map("kitchen_config_id")
  voidedBy          String?             @map("voided_by")
  reFiredAt         DateTime?           @map("re_fired_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  modifiers         OrderItemModifier[]

  @@map("order_items")
}

model OrderItemModifier {
  id              String    @id @default(uuid()) @map("id")
  orderItemId     String    @map("order_item_id")
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOptionId String   @map("modifier_option_id")
  name            String    @map("name")
  price           Float     @map("price")
  quantity        Int       @default(1) @map("quantity")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("order_item_modifiers")
}

model KOT {
  id              String            @id @default(uuid()) @map("id")
  kotNumber       String            @map("kot_number")
  orderId         String            @map("order_id")
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branchId        String            @map("branch_id")
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  kitchenConfigId String            @map("kitchen_config_id")
  status          String            @default("NEW") @map("status")
  priority        String            @default("NORMAL") @map("priority")
  waiterId        String?           @map("waiter_id")
  guestsCount     Int               @default(1) @map("guests_count")
  notes           String?           @map("notes")
  createdAt       DateTime          @default(now()) @map("created_at")
  items           KOTItem[]
  timers          KitchenTimerLog[]

  @@map("kots")
}

model KOTItem {
  id                String   @id @default(uuid()) @map("id")
  kotId             String   @map("kot_id")
  kot               KOT      @relation(fields: [kotId], references: [id], onDelete: Cascade)
  menuItemId        String   @map("menu_item_id")
  menuItemVariantId String?  @map("menu_item_variant_id")
  name              String   @map("name")
  quantity          Int      @map("quantity")
  status            String   @default("NEW") @map("status")
  notes             String?  @map("notes")
  modifierDesc      String?  @map("modifier_desc")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("kot_items")
}

model KitchenTimerLog {
  id        String   @id @default(uuid()) @map("id")
  kotId     String   @map("kot_id")
  kot       KOT      @relation(fields: [kotId], references: [id], onDelete: Cascade)
  action    String   @map("action")
  timestamp DateTime @default(now()) @map("timestamp")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("kitchen_timer_logs")
}

// --- Billing & Financial models ---

model Bill {
  id             String          @id @default(uuid()) @map("id")
  orderId        String          @map("order_id")
  branchId       String          @map("branch_id")
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  billNumber     String          @map("bill_number")
  subTotal       Float           @map("sub_total")
  discountAmount Float           @default(0) @map("discount_amount")
  taxAmount      Float           @default(0) @map("tax_amount")
  serviceCharge  Float           @default(0) @map("service_charge")
  tipsAmount     Float           @default(0) @map("tips_amount")
  grandTotal     Float           @map("grand_total")
  type           String          @map("type")
  status         String          @default("UNPAID") @map("status")
  createdBy      String          @map("created_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  taxDetails     BillTaxDetail[]
  payments       Payment[]
  refunds        Refund[]

  @@unique([branchId, billNumber])
  @@map("bills")
}

model BillTaxDetail {
  id        String   @id @default(uuid()) @map("id")
  billId    String   @map("bill_id")
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  taxName   String   @map("tax_name")
  rate      Float    @map("rate")
  amount    Float    @map("amount")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bill_tax_details")
}

model Payment {
  id              String   @id @default(uuid()) @map("id")
  billId          String   @map("bill_id")
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  method          String   @map("method")
  amount          Float    @map("amount")
  referenceNumber String?  @map("reference_number")
  transactionId   String?  @map("transaction_id")
  status          String   @default("SUCCESS") @map("status")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model Refund {
  id          String   @id @default(uuid()) @map("id")
  billId      String   @map("bill_id")
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount      Float    @map("amount")
  reason      String   @map("reason")
  approvedBy  String   @map("approved_by")
  status      String   @default("COMPLETED") @map("status")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("refunds")
}

model CashDrawerLog {
  id        String    @id @default(uuid()) @map("id")
  shiftId   String    @map("shift_id")
  shift     UserShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  action    String    @map("action")
  amount    Float     @map("amount")
  notes     String?   @map("notes")
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("cash_drawer_logs")
}

// --- Inventory & Suppliers models ---

model Supplier {
  id            String          @id @default(uuid()) @map("id")
  branchId      String          @map("branch_id")
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name          String          @map("name")
  code          String          @map("code")
  contactPerson String?         @map("contact_person")
  phone         String          @map("phone")
  email         String          @map("email")
  gstNumber     String?         @map("gst_number")
  address       String?         @map("address")
  creditLimit   Float           @default(0) @map("credit_limit")
  status        String          @default("ACTIVE") @map("status")
  createdAt     DateTime        @default(now()) @map("created_at")
  purchaseOrders PurchaseOrder[]

  @@unique([branchId, code])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @map("id")
  supplierId  String              @map("supplier_id")
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branchId    String              @map("branch_id")
  branch      Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  poNumber    String              @map("po_number")
  status      String              @default("DRAFT") @map("status")
  subTotal    Float               @map("sub_total")
  taxAmount   Float               @default(0) @map("tax_amount")
  grandTotal  Float               @map("grand_total")
  createdBy   String              @map("created_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  items       PurchaseOrderItem[]

  @@unique([branchId, poNumber])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id           String     @id @default(uuid()) @map("id")
  poId         String     @map("po_id")
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Float      @map("quantity")
  unitPrice    Float      @map("unit_price")
  discountAmt  Float      @default(0) @map("discount_amt")
  taxAmt       Float      @default(0) @map("tax_amt")
  grandTotal   Float      @map("grand_total")

  @@map("purchase_order_items")
}

model StockMovement {
  id           String     @id @default(uuid()) @map("id")
  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  branchId     String     @map("branch_id")
  type         String     @map("type")
  quantity     Float      @map("quantity")
  referenceId  String?    @map("reference_id")
  notes        String?    @map("notes")
  createdBy    String     @map("created_by")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("stock_movements")
}

model StockTransfer {
  id            String              @id @default(uuid()) @map("id")
  fromBranchId  String              @map("from_branch_id")
  toBranchId    String              @map("to_branch_id")
  status        String              @default("REQUESTED") @map("status")
  notes         String?             @map("notes")
  requestedBy   String              @map("requested_by")
  approvedBy    String?             @map("approved_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  items         StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id           String        @id @default(uuid()) @map("id")
  transferId   String        @map("transfer_id")
  transfer     StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  ingredientId String        @map("ingredient_id")
  ingredient   Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Float         @map("quantity")

  @@map("stock_transfer_items")
}

model WastageEntry {
  id           String     @id @default(uuid()) @map("id")
  branchId     String     @map("branch_id")
  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Float      @map("quantity")
  reason       String     @map("reason")
  status       String     @default("PENDING") @map("status")
  approvedBy   String?    @map("approved_by")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("wastage_entries")
}

model PhysicalCount {
  id            String   @id @default(uuid()) @map("id")
  branchId      String   @map("branch_id")
  expectedValue Float    @map("expected_value")
  actualValue   Float    @map("actual_value")
  varianceValue Float    @map("variance_value")
  notes         String?  @map("notes")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("physical_counts")
}

model UserSession {
  id             String   @id @default(uuid()) @map("id")
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken   String   @unique @map("refresh_token")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  deviceName     String?  @map("device_name")
  osName         String?  @map("os_name")
  clientAppName  String?  @map("client_app_name")
  status         String   @default("ACTIVE") @map("status")
  expiresAt      DateTime @map("expires_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("user_sessions")
}

model AuditLog {
  id        String   @id @default(uuid()) @map("id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  tenantId  String   @map("tenant_id")
  branchId  String?  @map("branch_id")
  action    String   @map("action")
  tableName String   @map("table_name")
  recordId  String   @map("record_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
