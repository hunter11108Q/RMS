# ==============================================================================
# RMS Environment Configuration Template (Example)
# ==============================================================================

# Server binding port
PORT=3000

# Node runtime mode (development, production, testing)
NODE_ENV=development

# Database connection URL (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres:supersecretpasswordchangeinprod@localhost:5432/rms_db?schema=public"

# Redis Cache Service connection URL
# Format: redis://[host]:[port]
REDIS_URL="redis://localhost:6379"

# Cryptographic secret for signing API JWT Access tokens
JWT_SECRET="gourmet-jwt-secret-verification-token-key-256"

# Cryptographic secret for signing API JWT Refresh tokens
JWT_REFRESH_SECRET="gourmet-jwt-refresh-verification-token-key-256"

# Allowed CORS client hosts origins (comma-separated or *)
CORS_ORIGIN="*"
