# ==============================================================================
# RMS ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to .env inside your execution environment (e.g. apps/backend/.env)
# ==============================================================================

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Connection (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL="postgresql://postgres:supersecretpasswordchangeinprod@localhost:5432/rms_db?schema=public"

# Redis Cache Connection
# Format: redis://[host]:[port]
REDIS_URL="redis://localhost:6379"

# Security Secrets (Use long, cryptographically secure keys in production)
JWT_SECRET="super-secret-jwt-signing-key-for-local-development"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key-for-local-development"

# CORS Policies
# Set to specific domains in production (e.g. https://pos.restaurant.com)
CORS_ORIGIN="*"

# Logging Level (Options: error, warn, info, debug)
LOG_LEVEL="info"
